{
  "name": "@minecraft-lan-tunnel/relay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=../desktop/resources/relay-server.cjs --external:bufferutil --external:utf-8-validate"
  },
  "dependencies": {
    "@minecraft-lan-tunnel/shared": "*",
    "@minecraft-lan-tunnel/tunnel-core": "*",
    "dotenv": "^16.4.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
