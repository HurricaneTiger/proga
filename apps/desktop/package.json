{
  "name": "@minecraft-lan-tunnel/desktop",
  "version": "0.1.0",
  "description": "Minecraft LAN Tunnel - play with friends over the internet",
  "author": "HurricaneTiger",
  "private": true,
  "main": "dist-main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.main.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "@minecraft-lan-tunnel/shared": "*",
    "@minecraft-lan-tunnel/tunnel-core": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "lucide-react": "^0.468.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.mc-lan-tunnel.app",
    "productName": "MC LAN Tunnel",
    "electronVersion": "33.2.0",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-main/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/relay-server.cjs",
        "to": "relay-server.cjs"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "MC-LAN-Tunnel-${version}-setup.exe"
    },
    "portable": {
      "artifactName": "MC-LAN-Tunnel-${version}-portable.exe"
    }
  }
}
